{
  "name": "tanzo",
  "version": "0.2.4",
  "description": "AI-native desktop workspace for planning, coding, and automation.",
  "main": "./out/main/index.js",
  "license": "Apache-2.0",
  "author": {
    "name": "f4tumnigrum",
    "email": "f4tumnigrum@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f4tumnigrum/Tanzo.git"
  },
  "homepage": "https://github.com/f4tumnigrum/Tanzo#readme",
  "bugs": {
    "url": "https://github.com/f4tumnigrum/Tanzo/issues"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "node --run typecheck:node && node --run typecheck:web",
    "diagnose:prompt-cache": "node scripts/prompt-cache-diagnostics.mjs",
    "test:node": "node --import tsx --test spike/*.spike.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "node --run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "node --run build && electron-builder --dir",
    "build:win": "node --run build && electron-builder --win",
    "build:mac": "node --run build && electron-builder --mac",
    "build:linux": "node --run build && electron-builder --linux"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "4.0.0-beta.67",
    "@ai-sdk/deepseek": "3.0.0-beta.55",
    "@ai-sdk/google": "4.0.0-beta.84",
    "@ai-sdk/mcp": "2.0.0-beta.66",
    "@ai-sdk/openai": "4.0.0-beta.76",
    "@ai-sdk/openai-compatible": "3.0.0-beta.57",
    "@ai-sdk/provider": "4.0.0-beta.19",
    "@ai-sdk/provider-utils": "5.0.0-beta.49",
    "@base-ui/react": "^1.4.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@tanstack/react-query": "5.100.11",
    "@tanstack/react-table": "^8.21.3",
    "@vscode/ripgrep": "^1.18.0",
    "ai": "7.0.0-beta.183",
    "better-sqlite3": "12.10.0",
    "chokidar": "5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-log": "^5.4.4",
    "fix-path": "^5.0.0",
    "i18next": "^26.2.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "next-themes": "0.4.6",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^7.15.1",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.7",
    "recharts": "3.8.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "simple-git": "3.36.0",
    "sonner": "2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "electron": "^41.7.0",
    "electron-builder": "^26.15.0",
    "electron-vite": "6.0.0-beta.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  }
}
